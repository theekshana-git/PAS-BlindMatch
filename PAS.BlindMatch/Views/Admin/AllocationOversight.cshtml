@model IEnumerable<PAS.BlindMatch.Models.Project>
@{
    ViewData["Title"] = "Project Allocation Oversight";
}

<div class="mt-4">
    <div class="mb-4">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">Allocation Oversight</h2>
        <p class="text-muted">Monitor and manage all student-supervisor pairings and project statuses.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 py-2">
            <span class="text-success small fw-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bolder mb-4">Filters</h5>
                <form method="get">
                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1 fw-bold">Search</label>
                        <input type="text" name="searchString" class="form-control border-secondary-subtle" placeholder="Search..." value="@Context.Request.Query["searchString"]" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1 fw-bold">Status</label>
                        <select name="statusFilter" class="form-select border-secondary-subtle" asp-items="ViewBag.StatusOptions">
                            <option value="">-- All Statuses --</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small text-muted mb-1 fw-bold">Category</label>
                        <select name="categoryFilter" class="form-select border-secondary-subtle" asp-items="ViewBag.CategoryOptions">
                            <option value="">-- All Categories --</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-medium mb-2">Apply Filters</button>
                    <a asp-action="AllocationOversight" class="btn btn-link text-muted text-decoration-none w-100 small">Clear All</a>
                </form>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bolder mb-4">Master List</h5>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-muted small fw-bold border-0">Project Title</th>
                                <th class="text-muted small fw-bold border-0">Category</th>
                                <th class="text-muted small fw-bold border-0">Student</th>
                                <th class="text-muted small fw-bold border-0">Supervisor</th>
                                <th class="text-muted small fw-bold border-0">Status</th>
                                <th class="text-muted small fw-bold border-0 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var project in Model)
                                {
                                    <tr>
                                        <td class="fw-medium text-truncate" style="max-width: 200px;" title="@project.Title">@project.Title</td>
                                        <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle rounded-pill">@(project.ResearchArea?.Name ?? "General")</span></td>
                                        <td class="small">@project.Student?.FirstName @project.Student?.LastName</td>
                                        <td class="small text-muted">
                                            @(project.MatchRequests?.FirstOrDefault(m => m.Status.ToString() == "Confirmed")?.Supervisor?.FirstName ?? "Not Assigned")
                                        </td>
                                        <td>
                                            <span class="badge @(project.Status.ToString() == "Matched" ? "bg-success" : "bg-warning text-dark") rounded-pill px-3">
                                                @project.Status
                                            </span>
                                        </td>
                                        <td style="text-align:right">
                                            <div class="d-flex justify-content-end align-items-center gap-2">
                                                <a asp-action="ReassignProject" asp-route-projectId="@project.Id"
                                                   class="btn btn-sm btn-outline-dark rounded-pill px-3">Reassign</a>

                                                <form method="post" asp-action="ResetProject" asp-route-projectId="@project.Id" class="m-0">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill px-3"
                                                            onclick="return confirm('This will break all existing matches for this project. Continue?')">
                                                        Reset
                                                    </button>
                                                </form>

                                                <form method="post" asp-action="DeleteAllocation" asp-route-projectId="@project.Id" class="m-0">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted small">No projects found matching the criteria.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>