@model PAS.BlindMatch.ViewModels.EditUserViewModel

@{
    ViewData["Title"] = "Edit User Profile";
}

<style>
    .admin-portal-container {
        max-width: 600px;
        margin: 2rem auto;
        font-family: sans-serif;
    }

    .form-section {
        background: #fdfdfd;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

    .form-group {
        margin-bottom: 1rem;
    }

        .form-group label {
            display: block;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

    .form-control {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
    }

    .btn-submit {
        background-color: #000;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
    }

        .btn-submit:hover {
            background-color: #000;
        }

    .btn-cancel {
        background-color: #000;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
        margin-left: 10px;
    }

    .text-danger {
        color: red;
        font-size: 0.875em;
    }
</style>

<div class="admin-portal-container">
    <h2>Edit User Profile</h2>

    <div class="form-section">
        <form asp-action="EditUser" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UniversityId"></label>
                <input asp-for="UniversityId" class="form-control" />
                <span asp-validation-for="UniversityId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NewPassword"></label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Optional..." />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Role">Assign Role</label>
                <select asp-for="Role" class="form-control">
                    <option value="Student">Student</option>
                    <option value="Supervisor">Supervisor</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <div style="margin-top: 20px;">
                <button type="submit" class="btn-submit">Save Changes</button>
                <a asp-action="UserManagement" class="btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}