@model PAS.BlindMatch.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit User Profile";
}

<div class="mt-4 mx-auto" style="max-width: 600px;">
    <div class="mb-4 text-center">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">Edit User Profile</h2>
        <p class="text-muted">Update credentials or reassign system roles.</p>
    </div>

    <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 p-md-5">
        <form asp-action="EditUser" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="FirstName" class="form-label small text-muted mb-1 fw-bold"></label>
                    <input asp-for="FirstName" class="form-control border-secondary-subtle" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="LastName" class="form-label small text-muted mb-1 fw-bold"></label>
                    <input asp-for="LastName" class="form-control border-secondary-subtle" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small text-muted mb-1 fw-bold"></label>
                <input asp-for="Email" type="email" class="form-control border-secondary-subtle" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="UniversityId" class="form-label small text-muted mb-1 fw-bold"></label>
                <input asp-for="UniversityId" class="form-control border-secondary-subtle" />
                <span asp-validation-for="UniversityId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label small text-muted mb-1 fw-bold">Assign Role</label>
                <select asp-for="Role" class="form-select border-secondary-subtle">
                    <option value="Student">Student</option>
                    <option value="Supervisor">Supervisor</option>
                    <option value="Admin">Admin</option>
                </select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="NewPassword" class="form-label small text-muted mb-1 fw-bold"></label>
                <input asp-for="NewPassword" type="password" class="form-control border-secondary-subtle" placeholder="Optional..." />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center border-top pt-4 mt-2">
                <a asp-action="UserManagement" class="text-muted text-decoration-none small fw-medium">Cancel</a>
                <button type="submit" class="btn btn-dark rounded-pill px-5 py-2 fw-medium">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}