@model IEnumerable<PAS.BlindMatch.Models.ResearchArea>
@{
    ViewData["Title"] = "Manage Research Areas";
}

<div class="mt-4">
    <div class="mb-4">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">Research Areas</h2>
        <p class="text-muted">Manage the global categories available for student projects.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 py-2">
            <span class="text-success small fw-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bolder mb-4">Add Category</h5>
                <form method="post" asp-action="AddResearchArea">
                    <div class="mb-4">
                        <label class="form-label small text-muted mb-1 fw-bold">Category Name</label>
                        <input type="text" name="areaName" class="form-control border-secondary-subtle" placeholder="e.g. Artificial Intelligence" required />
                    </div>
                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-medium">Add Category</button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bolder mb-4">Active Research Areas</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-muted small fw-bold border-0">ID</th>
                                <th class="text-muted small fw-bold border-0">Name</th>
                                <th class="text-muted small fw-bold border-0 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @foreach (var area in Model)
                            {
                                <tr>
                                    <td class="small text-muted font-monospace">@area.Id.ToString("D5")</td>
                                    <td class="fw-medium">@area.Name</td>
                                    <td class="text-end">
                                        <form method="post" asp-action="DeleteResearchArea" asp-route-id="@area.Id" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>