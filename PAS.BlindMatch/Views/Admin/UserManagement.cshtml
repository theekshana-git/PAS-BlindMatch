@model UserManagementViewModel

@{
    ViewData["Title"] = "Secure Account Creation";
}

<style>
    .admin-portal-container {
        max-width: 800px;
        margin: 2rem auto;
        font-family: sans-serif;
    }

    .form-section, .table-section {
        background: #fdfdfd;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 8px;
        margin-bottom: 2rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

        .form-group label {
            display: block;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

    .form-control {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
    }

    .btn-submit {
        background-color: #000;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
    }

        .btn-submit:hover {
            background-color: #000;
        }

    .users-table {
        width: 100%;
        border-collapse: collapse;
    }

        .users-table th, .users-table td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }

        .users-table th {
            background-color: #f8f9fa;
        }

    .success-alert {
        color: #000;
        background-color: #d1e7dd;
        padding: 15px;
        border-radius: 4px;
        margin-bottom: 20px;
    }

    .text-danger {
        color: red;
        font-size: 0.875em;
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 0.875em;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        color: white;
    }

    .btn-edit {
        background-color: #000;
        color: #ffff;
    }

        .btn-edit:hover {
            background-color: #000;
        }

    .btn-delete {
        background-color: #dc3545;
        margin-left: 5px;
    }

        .btn-delete:hover {
            background-color: #c82333;
        }

    .action-form {
        display: inline;
    }
</style>

<div class="admin-portal-container">
    <h2>User Management Portal</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="form-section">
        <h3>Create New Account</h3>
        <form asp-action="UserManagement" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="FirstName">First Name</label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName">Last Name</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UniversityId">University ID</label>
                <input asp-for="UniversityId" class="form-control" />
                <span asp-validation-for="UniversityId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Role">Assign Role</label>
                <select asp-for="Role" class="form-control">
                    <option value="">-- Select a Role --</option>
                    <option value="Student">Student</option>
                    <option value="Supervisor">Supervisor</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">Create Account</button>
        </form>
    </div>

    <div class="table-section">
        <h3>Active System Users</h3>
        <table class="users-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ActiveUsers != null && Model.ActiveUsers.Any())
                {
                    foreach (var user in Model.ActiveUsers)
                    {
                        <tr>
                            <td>@user.UniversityId</td>
                            <td>@user.FirstName</td>
                            <td>@user.LastName</td>
                            <td>@user.Email</td>
                            <td>
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn-sm btn-edit">Edit</a>

                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="action-form" onsubmit="return confirm('Are you sure you want to delete @user.FirstName?');">
                                    <button type="submit" class="btn-sm btn-delete">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" style="text-align: center;">No active users found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}