@model PAS.BlindMatch.ViewModels.UserManagementViewModel

@{
    ViewData["Title"] = "User Management";
}

<div class="mt-4">
    <div class="mb-4">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">User Management</h2>
        <p class="text-muted">Securely provision accounts for students and faculty.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-success-subtle bg-success bg-opacity-10" role="alert">
            <span class="text-success fw-medium">@TempData["SuccessMessage"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bolder mb-4">Create Account</h5>

                <form asp-action="UserManagement" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label asp-for="FirstName" class="form-label small text-muted mb-1 fw-bold">First Name</label>
                            <input asp-for="FirstName" class="form-control border-secondary-subtle" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="LastName" class="form-label small text-muted mb-1 fw-bold">Last Name</label>
                            <input asp-for="LastName" class="form-control border-secondary-subtle" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small text-muted mb-1 fw-bold">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control border-secondary-subtle" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UniversityId" class="form-label small text-muted mb-1 fw-bold">University ID</label>
                        <input asp-for="UniversityId" class="form-control border-secondary-subtle" />
                        <span asp-validation-for="UniversityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small text-muted mb-1 fw-bold">Temporary Password</label>
                        <input asp-for="Password" type="password" class="form-control border-secondary-subtle" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Role" class="form-label small text-muted mb-1 fw-bold">Assign Role</label>
                        <select asp-for="Role" class="form-select border-secondary-subtle">
                            <option value="">-- Select Role --</option>
                            <option value="Student">Student</option>
                            <option value="Supervisor">Supervisor</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-medium">Provision Account</button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bolder mb-4">Active System Users</h5>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-muted small fw-bold border-0">ID</th>
                                <th class="text-muted small fw-bold border-0">Name</th>
                                <th class="text-muted small fw-bold border-0">Email</th>
                                <th class="text-muted small fw-bold border-0 text-center">Role</th>
                                <th class="text-muted small fw-bold border-0 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @if (Model.ActiveUsers != null && Model.ActiveUsers.Any())
                            {
                                foreach (var user in Model.ActiveUsers)
                                {
                                    <tr>
                                        <td class="small font-monospace text-muted">@user.UniversityId</td>
                                        <td class="fw-medium">@user.FirstName @user.LastName</td>
                                        <td class="small text-muted">@user.Email</td>
                                        <td class="text-center">
                                            @if (user.Role == "Admin")
                                            {
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle rounded-pill px-3 py-1">Admin</span>
                                            }
                                            else if (user.Role == "Supervisor")
                                            {
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-3 py-1">Supervisor</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle rounded-pill px-3 py-1">Student</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-end align-items-center gap-2">
                                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-dark rounded-pill px-3">Edit</a>
                                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="m-0" onsubmit="return confirm('WARNING: Are you sure you want to delete @user.FirstName?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted small">No active users found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}