@model PAS.BlindMatch.Models.Project
@{
    ViewData["Title"] = "My Project Submission";
    bool hasMatchedProject = ViewBag.HasMatchedProject ?? false;
}

<div class="mt-4 mx-auto" style="max-width: 700px;">
    <div class="mb-4">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">Project Proposal</h2>
        <p class="text-muted">Submit or edit your idea for the BlindMatch system.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 py-2">
            <span class="text-success small fw-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (hasMatchedProject)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 p-4 rounded-4 shadow-sm">
            <h4 class="fw-bold">🔒 Submission Locked</h4>
            <p class="mb-0">Congratulations! You have already been matched with a supervisor. You cannot submit or edit project proposals.</p>
        </div>
    }
    else
    {
        <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 p-md-5">
            <form asp-action="@(Model?.Id > 0 ? "EditProject" : "SubmitProject")" asp-controller="Student" method="post">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                @if (Model?.Id > 0)
                {
                    <input type="hidden" asp-for="Id" />
                }

                <div class="mb-3">
                    <label asp-for="Title" class="form-label small text-muted mb-1 fw-bold">Project Title</label>
                    <input asp-for="Title" class="form-control border-secondary-subtle" placeholder="Enter a descriptive title..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ResearchAreaId" class="form-label small text-muted mb-1 fw-bold">Research Area</label>
                    <select asp-for="ResearchAreaId" class="form-select border-secondary-subtle" asp-items="ViewBag.ResearchAreas">
                        <option value="">-- Select a Category --</option>
                    </select>
                    <span asp-validation-for="ResearchAreaId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Abstract" class="form-label small text-muted mb-1 fw-bold">Project Abstract</label>
                    <textarea asp-for="Abstract" class="form-control border-secondary-subtle" rows="6" placeholder="Provide a detailed abstract (minimum 50 characters)..."></textarea>
                    <span asp-validation-for="Abstract" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="TechnicalStack" class="form-label small text-muted mb-1 fw-bold">Technical Stack</label>
                    <input asp-for="TechnicalStack" class="form-control border-secondary-subtle" placeholder="e.g., React, Python, AWS..." />
                    <span asp-validation-for="TechnicalStack" class="text-danger small"></span>
                </div>

                <div class="text-end border-top pt-4">
                    <button type="submit" class="btn btn-dark rounded-pill px-5 py-2 fw-medium">
                        @(Model?.Id > 0 ? "Update Proposal" : "Submit Proposal")
                    </button>
                </div>
            </form>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}