@model IEnumerable<PAS.BlindMatch.Models.Project>
@{
    ViewData["Title"] = "My Proposals";
}

<div class="mt-4">
    <div class="mb-4">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">My Proposals</h2>
        <p class="text-muted">View the status of all your submitted project ideas.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 py-2">
            <span class="text-success small fw-medium">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-danger-subtle bg-danger bg-opacity-10 py-2">
            <span class="text-danger small fw-medium">@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 text-muted card border-secondary-subtle rounded-4 shadow-sm">
                <h5 class="fw-bold">No proposals found.</h5>
                <p>You haven't submitted any projects yet. Go to your submission form to propose an idea!</p>
            </div>
        }
        else
        {
            @foreach (var project in Model)
            {
                <div class="col-12">
                    <div class="card border-secondary-subtle shadow-sm rounded-4 p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h4 class="fw-bolder mb-1">@project.Title</h4>
                                <div class="d-flex gap-3 text-muted small">
                                    <span><span class="fw-bold">Category:</span> @(project.ResearchArea?.Name ?? "None")</span>
                                    <span><span class="fw-bold">Tech Stack:</span> @(string.IsNullOrEmpty(project.TechnicalStack) ? "N/A" : project.TechnicalStack)</span>
                                </div>
                            </div>
                            <span class="badge @(project.Status.ToString() == "Matched" ? "bg-success" : project.Status.ToString() == "Rejected" ? "bg-danger" : "bg-warning text-dark") rounded-pill px-3 py-2 fw-bold">
                                @project.Status
                            </span>
                        </div>

                        <div class="bg-light p-3 rounded-3 border border-secondary-subtle mb-3">
                            <p class="small text-muted text-uppercase mb-1 fw-bold" style="letter-spacing: 0.5px;">Abstract</p>
                            <p class="mb-0 small text-dark">@project.Abstract</p>
                        </div>
                        @if (project.Status == PAS.BlindMatch.Enums.ProjectStatus.Matched)
                        {
                            var confirmedMatch = project.MatchRequests.FirstOrDefault(m => m.Status == PAS.BlindMatch.Enums.MatchStatus.Confirmed);
                            if (confirmedMatch != null)
                            {
                                <div class="bg-white p-3 rounded-3 border border-success-subtle d-inline-block shadow-sm mt-3 w-100">
                                    <p class="small text-muted text-uppercase mb-1 fw-bold" style="letter-spacing: 0.5px;">Supervisor Identity Revealed</p>
                                    <h6 class="mb-1 fw-bold">@confirmedMatch.Supervisor.FirstName @confirmedMatch.Supervisor.LastName</h6>
                                    <p class="mb-0 small">
                                        <a href="mailto:@confirmedMatch.Supervisor.Email" class="text-success text-decoration-none">@confirmedMatch.Supervisor.Email</a>
                                    </p>
                                </div>
                            }
                        }
                        @if (project.Status != PAS.BlindMatch.Enums.ProjectStatus.Matched)
                        {
                            <div class="d-flex justify-content-end gap-2 border-top pt-3">
                                <a asp-action="EditProject" asp-route-projectId="@project.Id" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-medium">Edit</a>
                                <form asp-action="WithdrawProject" method="post" class="m-0" onsubmit="return confirm('Are you sure you want to withdraw this proposal?');">
                                    <input type="hidden" name="projectId" value="@project.Id" />
                                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4 btn-sm fw-medium">Withdraw</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>