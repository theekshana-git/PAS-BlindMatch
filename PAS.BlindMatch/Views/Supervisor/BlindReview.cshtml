@model IEnumerable<PAS.BlindMatch.ViewModels.ProjectCardViewModel>
@{
    ViewData["Title"] = "Blind Review";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">Blind Review</h2>
            <p class="text-muted">Anonymous proposals matching your expertise.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 py-2">
            <span class="text-success small fw-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 text-muted">
                <p>No pending projects currently match your expertise tags.</p>
            </div>
        }

        @foreach (var project in Model)
        {
            <div class="col-md-6">
                <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle rounded-pill px-3 py-1">@project.ResearchArea</span>
                        <span class="badge bg-light text-dark border rounded-pill px-3 py-1 fw-bold" style="letter-spacing: 0.5px;">ANONYMOUS</span>
                    </div>
                    <h5 class="fw-bolder text-dark mb-2">@project.Title</h5>
                    <p class="text-muted small mb-3">@project.Abstract</p>
                    <p class="small fw-bold text-dark mb-4">Tech Stack: <span class="fw-normal text-muted">@project.TechStack</span></p>

                    <div class="mt-auto pt-3 border-top text-end">
                        <form asp-action="ExpressInterest" method="post" class="m-0">
                            <input type="hidden" name="projectId" value="@project.ProjectId" />
                            <button type="submit" class="btn btn-dark rounded-pill px-4 btn-sm">Express Interest &rarr;</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>