@model IEnumerable<PAS.BlindMatch.ViewModels.ProjectCardViewModel>
@{
    ViewData["Title"] = "My Matches";
}

<div class="mt-4">
    <div class="mb-4">
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">My Matches</h2>
        <p class="text-muted">Projects you are reviewing and supervising.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-success-subtle bg-success bg-opacity-10 py-2">
            <span class="text-success small fw-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 text-muted">
                <p>You have not expressed interest in any projects yet.</p>
            </div>
        }

        @foreach (var project in Model)
        {
            bool isMatched = project.Status == "Matched";

            <div class="col-12">
                <div class="card border-secondary-subtle shadow-sm rounded-4 p-4 @(isMatched ? "border-success-subtle bg-success bg-opacity-10" : "")">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bolder mb-0">@project.Title</h4>
                        <span class="badge @(isMatched ? "bg-success" : "bg-warning text-dark") rounded-pill px-3 py-2 fw-bold">
                            @(isMatched ? "MATCH CONFIRMED" : "UNDER REVIEW")
                        </span>
                    </div>
                    <p class="text-muted mb-4">@project.Abstract</p>

                    @if (isMatched)
                    {
                        <div class="bg-white p-3 rounded-3 border border-success-subtle d-inline-block shadow-sm">
                            <p class="small text-muted text-uppercase mb-1 fw-bold" style="letter-spacing: 0.5px;">Student Identity Revealed</p>
                            <h6 class="mb-0 fw-bold">@project.StudentName (@project.StudentUniversityId)</h6>
                            <a href="mailto:@project.StudentEmail" class="small text-success text-decoration-none fw-medium">@project.StudentEmail</a>
                        </div>
                    }
                    else
                    {
                        <div class="bg-light p-3 rounded-3 border border-secondary-subtle d-flex align-items-center justify-content-between w-100">
                            <div>
                                <p class="small text-muted text-uppercase mb-1 fw-bold" style="letter-spacing: 0.5px;">Student Status</p>
                                <h6 class="mb-0 text-muted fst-italic">Anonymous until match is confirmed.</h6>
                            </div>
                            <form asp-action="ConfirmMatch" method="post" class="m-0">
                                <input type="hidden" name="matchRequestId" value="@project.MatchRequestId" />
                                <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">Confirm Match & Reveal</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>