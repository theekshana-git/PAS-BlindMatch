<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PAS.BlindMatch.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
        }

        .navbar {
            border-bottom: 1px solid #eaeaea;
        }

        .nav-link {
            font-weight: 500;
            color: #666 !important;
            transition: color 0.2s;
        }

            .nav-link:hover {
                color: #000 !important;
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white py-3 shadow-sm-none">
            <div class="container">
                <a class="navbar-brand fw-bolder text-dark" asp-area="" asp-controller="Dashboard" asp-action="Index" style="letter-spacing: -0.5px;">
                    <span style="width: 12px; height: 12px; background-color: #000; border-radius: 50%; display: inline-block; margin-right: 6px;"></span>
                    BlindMatch.
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item me-2"><a class="nav-link" asp-controller="Admin" asp-action="AllocationOversight">Oversight</a></li>
                            <li class="nav-item me-2"><a class="nav-link" asp-controller="Admin" asp-action="UserManagement">Users</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ResearchAreas">Research Areas</a></li>
                        }
                        else if (User.IsInRole("Supervisor"))
                        {
                            <li class="nav-item me-2"><a class="nav-link" asp-controller="Supervisor" asp-action="BlindReview">Blind Review</a></li>
                            <li class="nav-item me-2"><a class="nav-link" asp-controller="Supervisor" asp-action="MyMatches">My Matches</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="Expertise">Expertise</a></li>
                        }
                        else if (User.IsInRole("Student"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="MyProject">My Proposals</a></li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 d-flex flex-column">
        <main role="main" class="pb-3 flex-grow-1 d-flex flex-column">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top py-4 bg-white mt-auto">
        <div class="container text-center text-muted" style="font-size: 0.85rem;">
            &copy; 2026 BlindMatch System &mdash; <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none border-bottom">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>