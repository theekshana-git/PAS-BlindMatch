@using Microsoft.AspNetCore.Identity
@using PAS.BlindMatch.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-4">
            <span class="text-muted small fw-medium">@User.Identity?.Name</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Dashboard", new { area = "" })">
                <button type="submit" class="btn btn-sm btn-dark rounded-pill px-4 fw-medium">Sign out</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark fw-bold" asp-area="Identity" asp-page="/Account/Login">Sign in &rarr;</a>
        </li>
    }
</ul>