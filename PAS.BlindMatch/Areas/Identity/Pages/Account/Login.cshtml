@page
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="w-100 flex-grow-1 d-flex justify-content-center mt-5 pt-5">
    <div style="max-width: 380px; width: 100%;">

        <div class="text-center mb-5">
            <h1 class="fw-bolder text-dark mb-2" style="letter-spacing: -1px;">Welcome back.</h1>
            <p class="text-muted">Enter your university credentials to continue.</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control bg-transparent border-secondary-subtle" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="text-muted">University Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control bg-transparent border-secondary-subtle" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="text-muted">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
                <div class="form-check">
                    <input class="form-check-input border-secondary" asp-for="Input.RememberMe" />
                    <label class="form-check-label text-muted small" asp-for="Input.RememberMe">
                        Stay signed in
                    </label>
                </div>
                <a id="forgot-password" class="small text-muted text-decoration-none border-bottom" asp-page="./ForgotPassword">Forgot Password?</a>
            </div>

            <button id="login-submit" type="submit" class="btn btn-dark w-100 py-3 fw-bold rounded-3 shadow-sm">
                Sign In
            </button>
        </form>

        <div class="text-center mt-5 text-muted" style="font-size: 0.8rem;">
            <em>System access is restricted to authorized faculty and students. Contact administration for account setup.</em>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}